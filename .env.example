# SheetFu — Environment Variables

# Required: Google Sheet ID (from URL: docs.google.com/spreadsheets/d/{SHEET_ID}/edit)
SHEET_ID=your-google-sheet-id

# Auth Option A: Service Account JSON file (recommended for local dev)
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Auth Option B: Inline credentials (for Cloudflare Pages / serverless)
GOOGLE_SERVICE_ACCOUNT_EMAIL=xxx@xxx.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# Optional: Restrict API access to specific emails (comma-separated)
# Works with Cloudflare Access cf-access-authenticated-user-email header
ALLOWED_EMAILS=user@example.com,family@example.com
